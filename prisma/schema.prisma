generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Institution {
  id                  String   @id @default("global")
  name                String
  ictEmail            String
  updatedAt           DateTime @updatedAt
  matricMode          String   @default("MANUAL")
  matricSerialTracker Int      @default(0)
}

model User {
  id              String      @id
  email           String      @unique
  staffId         String?     @unique
  role            Role        @default(ADMIN)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  departmentId    String?
  name            String?
  createdCourses  Course[]    @relation("CourseAdmin")
  assignedCourses Course[]    @relation("CourseLecturer")
  department      Department? @relation(fields: [departmentId], references: [id])
}

model Faculty {
  id          String       @id @default(cuid())
  name        String       @unique
  departments Department[]
}

model Department {
  id        String    @id @default(cuid())
  name      String    @unique
  facultyId String
  courses   Course[]
  faculty   Faculty   @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  students  Student[]
  lecturers User[]
}

model Student {
  id           String       @id @default(uuid())
  matricNumber String       @unique
  firstName    String
  lastName     String
  level        String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  departmentId String
  enrollments  Enrollment[]
  proctorLogs  ProctorLog[]
  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
}

model Course {
  id           String       @id @default(cuid())
  code         String       @unique
  title        String
  adminId      String?
  lecturerId   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  departmentId String
  level        String
  admin        User?        @relation("CourseAdmin", fields: [adminId], references: [id], onDelete: Cascade)
  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  lecturer     User?        @relation("CourseLecturer", fields: [lecturerId], references: [id])
  students     Enrollment[]
  exams        Exam[]
}

model Enrollment {
  id         String   @id @default(uuid())
  courseId   String
  studentId  String
  enrolledAt DateTime @default(now())
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
}

model Exam {
  id          String       @id @default(uuid())
  courseId    String
  title       String
  startTime   DateTime
  endTime     DateTime
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  proctorLogs ProctorLog[]
}

model ProctorLog {
  id             String   @id @default(uuid())
  examId         String
  studentId      String
  infractionType String
  details        String?
  timestamp      DateTime @default(now())
  exam           Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model ExamToken {
  id           String   @id @default(cuid())
  examId       String
  matricNumber String
  pin          String   @unique
  isUsed       Boolean  @default(false)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

enum Role {
  ADMIN
  LECTURER
}
