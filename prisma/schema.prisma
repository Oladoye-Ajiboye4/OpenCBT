generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Institution {
  id                  String   @id @default(cuid())
  name                String
  ictEmail            String
  matricMode          String   @default("MANUAL")
  matricSerialTracker Int      @default(0)
  adminId             String   @unique
  admin               User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  updatedAt           DateTime @updatedAt
  institutionType     String   @default("UNIVERSITY")
  currentAcademicYear String?
  currentTerm         String?
}

model User {
  id              String      @id
  email           String      @unique
  staffId         String?     @unique
  role            Role        @default(ADMIN)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  departmentId    String?
  name            String?
  createdCourses  Course[]    @relation("CourseAdmin")
  assignedCourses Course[]    @relation("CourseLecturer")
  department      Department? @relation(fields: [departmentId], references: [id])
  institution     Institution?
}

model Faculty {
  id          String       @id @default(cuid())
  name        String       @unique
  departments Department[]
}

model Department {
  id        String    @id @default(cuid())
  name      String    @unique
  facultyId String
  courses   Course[]
  faculty   Faculty   @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  students  Student[]
  lecturers User[]
}

model Student {
  id           String       @id @default(uuid())
  matricNumber String       @unique
  firstName    String
  lastName     String
  email        String
  level        String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  departmentId String
  enrollments  Enrollment[]
  examResponses ExamResponse[]
  results      Result[]
  proctorLogs  ProctorLog[]
  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
}

model Course {
  id           String       @id @default(cuid())
  code         String       @unique
  title        String
  adminId      String?
  lecturerId   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  departmentId String
  level        String
  admin        User?        @relation("CourseAdmin", fields: [adminId], references: [id], onDelete: Cascade)
  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  lecturer     User?        @relation("CourseLecturer", fields: [lecturerId], references: [id])
  students     Enrollment[]
  exams        Exam[]
}

model Enrollment {
  id         String   @id @default(uuid())
  courseId   String
  studentId  String
  status     String   @default("ACTIVE")
  sessionStatus String @default("PENDING")
  currentQuestion Int  @default(1)
  lastPing DateTime?
  enrolledAt DateTime @default(now())
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
}

model Exam {
  id            String       @id @default(uuid())
  courseId      String
  title         String
  duration      Int
  scheduledDate DateTime
  status        String       @default("UPCOMING")
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  course        Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  questions     Question[]
  responses     ExamResponse[]
  results       Result[]
  proctorLogs   ProctorLog[]
}

model Question {
  id            String   @id @default(cuid())
  examId        String
  text          String   @db.Text
  options       Json
  correctAnswer String
  marks         Int      @default(1)
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
}

model Result {
  id         String   @id @default(cuid())
  studentId  String
  examId     String
  score      Int
  totalMarks Int
  status     String   @default("PENDING")
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([studentId, examId])
}

model ExamResponse {
  id             String   @id @default(cuid())
  studentId      String
  examId         String
  questionId     String
  selectedOption String
  updatedAt      DateTime @updatedAt
  student        Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  exam           Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@unique([studentId, examId, questionId])
}

model ProctorLog {
  id          String   @id @default(cuid())
  studentId   String
  examId      String
  anomalyType String
  description String
  snapshotUrl String?  @db.Text
  createdAt   DateTime @default(now())
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model ExamToken {
  id           String   @id @default(cuid())
  examId       String
  matricNumber String
  pin          String   @unique
  isUsed       Boolean  @default(false)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

enum Role {
  ADMIN
  LECTURER
}
