generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  LECTURER
}

model Institution {
  id                   String   @id @default("global")
  name                 String   // e.g., "Ladoke Akintola University of Technology"
  ictEmail             String   // e.g., "exams@lautech.edu.ng"
  matricMode           String   @default("MANUAL") // "MANUAL" or "AUTO"
  matricSerialTracker  Int      @default(0) // Tracks the last used serial
  updatedAt            DateTime @updatedAt
}


model User {
  id          String   @id
  email       String   @unique
  name        String?
  staffId     String?  @unique
  role        Role     @default(ADMIN)
  departmentId String? // Added for Lecturer relation to Department
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  department      Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  createdCourses  Course[]  @relation("AdminCourses")
  assignedCourses Course[]  @relation("LecturerCourses")
}

model Faculty {
  id          String       @id @default(cuid())
  name        String       @unique // e.g., "Computing and Informatics"
  departments Department[]
}

model Department {
  id          String     @id @default(cuid())
  name        String     @unique // e.g., "Computer Science"
  facultyId   String
  faculty     Faculty    @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  students    Student[]
  lecturers   User[]     // Relation to User where role=LECTURER
  courses     Course[]
}

model Student {
  id           String   @id @default(uuid())
  matricNumber String   @unique
  firstName    String
  lastName     String
  departmentId String
  level        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  enrollments  Enrollment[]
  proctorLogs  ProctorLog[]
}

model Course {
  id          String   @id @default(uuid())
  code        String   @unique
  title       String
  adminId     String
  lecturerId  String?
  departmentId String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  department  Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  admin       User     @relation("AdminCourses", fields: [adminId], references: [id], onDelete: Cascade)
  lecturer    User?    @relation("LecturerCourses", fields: [lecturerId], references: [id], onDelete: SetNull)
  students    Enrollment[]
  exams       Exam[]
}

model Enrollment {
  id         String   @id @default(uuid())
  courseId   String
  studentId  String
  enrolledAt DateTime @default(now())

  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId])
}

model Exam {
  id        String   @id @default(uuid())
  courseId  String
  title     String
  startTime DateTime
  endTime   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  proctorLogs ProctorLog[]
}

model ProctorLog {
  id             String   @id @default(uuid())
  examId         String
  studentId      String
  infractionType String   
  details        String?  
  timestamp      DateTime @default(now())

  exam    Exam    @relation(fields: [examId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}

model ExamToken {
  id           String   @id @default(cuid())
  examId       String
  matricNumber String
  pin          String   @unique
  isUsed       Boolean  @default(false)
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}
